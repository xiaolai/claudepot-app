{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claudepot",
  "version": "0.1.6",
  "identifier": "com.claudepot.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:11220",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claudepot",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 21 },
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/claudepot-cli"],
    "category": "DeveloperTool",
    "shortDescription": "Multi-account Claude Code / Desktop switcher",
    "longDescription": "Manage multiple Anthropic Claude Code and Claude Desktop accounts. Switch the active account in seconds without re-authenticating.",
    "publisher": "HANDO K.K.",
    "homepage": "https://github.com/xiaolai/claudepot-app",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5MEE3NkM3RUY3OEI3OUYKUldTZnQzanZ4M1lLeVZDNSttZ2pUbytmMW5panIwNkpqbzY4MmJNVDdicHovY09wYmlBemRnSVYK",
      "endpoints": [
        "https://github.com/xiaolai/claudepot-app/releases/latest/download/latest.json"
      ]
    }
  }
}
