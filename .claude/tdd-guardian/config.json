{
  "enabled": true,
  "projectType": "polyglot",
  "stacks": {
    "rust": {
      "packageManager": "cargo",
      "testCommand": "cargo test --workspace",
      "coverageCommand": "cargo llvm-cov --workspace --json --output-path coverage-rust.json",
      "coverageSummaryPath": "coverage-rust.json",
      "mutationCommand": "cargo mutants --workspace --timeout 60"
    },
    "react": {
      "packageManager": "pnpm",
      "testCommand": "pnpm test",
      "coverageCommand": "pnpm test:coverage",
      "coverageSummaryPath": "coverage/coverage-summary.json",
      "mutationCommand": null
    }
  },
  "testCommand": "cargo test --workspace && pnpm test",
  "coverageCommand": null,
  "thresholds": {
    "lines": 100,
    "functions": 100,
    "branches": 100,
    "statements": 100,
    "mutationKillRate": 80
  },
  "gates": {
    "preImplementation": {
      "requiredRedTests": true,
      "enforceTestFirst": true
    },
    "postImplementation": {
      "requireAllGreen": true,
      "requireCoverageThreshold": false,
      "requireNoRegressions": true
    }
  },
  "notes": {
    "rust_coverageTool": "cargo-llvm-cov NOT installed. Install: cargo install cargo-llvm-cov",
    "rust_mutationTool": "cargo-mutants NOT installed. Install: cargo install cargo-mutants",
    "react_coverage": "@vitest/coverage-v8 installed, run pnpm test:coverage",
    "coverageGateDisabled": "Disabled until cargo-llvm-cov is installed. Enable with requireCoverageThreshold: true",
    "lastUpdated": "2026-04-14"
  }
}
