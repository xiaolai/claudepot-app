# Database — Neon Postgres (serverless HTTP driver)
NEON_DATABASE_URL=

# Auth.js v5 — see src/lib/auth.ts
AUTH_SECRET=

# OAuth providers (each pair is optional; missing pair drops the
# provider from the sign-in page rather than breaking the build)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend — magic-link sign-in + transactional mail (digest, etc.).
# Leaving RESEND_API_KEY blank disables the email path silently.
RESEND_API_KEY=
EMAIL_FROM=

# Public-facing canonical URL — used by sitemap, RSS, OG, and the
# weekly digest. Defaults to https://claudepot.com when unset.
NEXT_PUBLIC_SITE_URL=

# Editorial — the scoring runtime (src/lib/editorial/) authenticates via the
# Claude Code CLI's OAuth session (no API key needed). Run `claude /login` once
# in your shell to set it up. The runtime uses @anthropic-ai/claude-agent-sdk.

# AI policy moderator — runs on submissions before publish. See
# dev-docs/policy-moderator-plan.md and src/lib/moderation/.
#
# In Vercel (prod + preview): set MODERATION_ENABLED=1 and OPENAI_API_KEY.
# Locally: leave MODERATION_ENABLED unset to default to disabled — the
# moderate() call short-circuits to a synthetic 'pass' verdict, so you
# can run `pnpm dev` without an OpenAI key. Set MODERATION_ENABLED=1 to
# exercise the real path against your local Postgres.
OPENAI_API_KEY=
MODERATION_ENABLED=

# Social — marketing-channel publishing (src/lib/social/)

# Bluesky — free; create app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# X — paid API access required (Basic ≈ $200/mo). Skip until tier is provisioned.
# Create at https://developer.x.com/en/portal/dashboard with read+write scopes.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
